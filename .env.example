PORT=3010
NODE_ENV=development
DATABASE_URL=./data/app.db
CORS_ORIGIN=*
FILE_STORAGE_DRIVER=local
UPLOADS_LOCAL_DIR=./data/uploads
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=uploads
AZURE_STORAGE_ACCESS_TIER=Cool
# Long random string used to unlock GM mode. Treat it like a password.
# Generate one with: openssl rand -base64 48
GM_API_KEY=replace-with-a-long-random-string
MAX_UPLOAD_MB=30
# Shared secret between frontend and backend — must match VITE_CLIENT_SECRET in the frontend .env
CLIENT_SECRET=generate-a-strong-random-secret-here
# Secret used to sign GM JWT tokens — must be long and random in production
# Generate with: openssl rand -base64 64
JWT_SECRET=generate-a-long-random-secret-here
JWT_EXPIRES_IN=8h
